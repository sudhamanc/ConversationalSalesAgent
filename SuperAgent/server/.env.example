# =============================================================================
# SuperAgent Server Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Google AI / Gemini ---
GOOGLE_API_KEY=your-gemini-api-key-here
# Options: gemini-1.5-flash (more free quota), gemini-2.0-flash (newer but stricter limits)
GEMINI_MODEL=gemini-1.5-flash
LLM_PROVIDER=google

# --- Model Parameters ---
MODEL_TEMPERATURE=0.7
MODEL_TOP_P=0.9
MODEL_TOP_K=40
MODEL_MAX_OUTPUT_TOKENS=2048

# --- Agent ---
AGENT_NAME=super_sales_agent
SYSTEM_MESSAGE=You are a professional B2B sales assistant for a telecommunications company.
ENABLE_SUB_AGENTS=true

# --- Safety Thresholds ---
# Options: BLOCK_NONE, BLOCK_LOW_AND_ABOVE, BLOCK_MEDIUM_AND_ABOVE, BLOCK_ONLY_HIGH
SAFETY_DANGEROUS=BLOCK_LOW_AND_ABOVE
SAFETY_HARASSMENT=BLOCK_LOW_AND_ABOVE
SAFETY_HATE_SPEECH=BLOCK_LOW_AND_ABOVE
SAFETY_SEXUALLY_EXPLICIT=BLOCK_LOW_AND_ABOVE

# --- Rate Limiting ---
RATE_LIMIT_RPM=20
RATE_LIMIT_RPH=200
RATE_LIMIT_BURST=5

# --- Session ---
SESSION_SECRET_KEY=change-me-in-production
SESSION_TOKEN_EXPIRY_MIN=60
MAX_HISTORY_LENGTH=50

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info
DEBUG=false

# --- Email Notifications (CustomerCommunicationAgent) ---
# Set SMTP_ENABLED=true to send real emails; false = simulation mode (default)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=B2B Sales Notifications
