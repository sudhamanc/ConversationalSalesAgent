# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# Agent Configuration
AGENT_NAME=payment_agent
LOG_LEVEL=INFO

# Payment Gateway Configuration (adjust based on provider)
PAYMENT_GATEWAY_API_KEY=your_payment_gateway_key
PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret
PAYMENT_GATEWAY_ENVIRONMENT=sandbox  # or production

# Credit Check Service
CREDIT_CHECK_API_KEY=your_credit_check_api_key
CREDIT_CHECK_ENDPOINT=https://api.creditcheck.example.com

# Security
ENCRYPTION_KEY=your_encryption_key_for_sensitive_data

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
