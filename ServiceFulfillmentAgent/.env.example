# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Agent Configuration
AGENT_NAME=service_fulfillment_agent
LOG_LEVEL=INFO

# Scheduling System Configuration
SCHEDULING_API_KEY=your_scheduling_api_key
SCHEDULING_API_ENDPOINT=https://api.scheduling.example.com

# Equipment Management System
EQUIPMENT_API_KEY=your_equipment_api_key
EQUIPMENT_API_ENDPOINT=https://api.equipment.example.com

# Service Activation System
ACTIVATION_API_KEY=your_activation_api_key
ACTIVATION_API_ENDPOINT=https://api.activation.example.com

# Technician Dispatch System
DISPATCH_API_KEY=your_dispatch_api_key
DISPATCH_API_ENDPOINT=https://api.dispatch.example.com

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Business Hours (for scheduling)
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
BUSINESS_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday
